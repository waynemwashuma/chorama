---
import { getCollection } from "astro:content";
import Example from "@layouts/Example.astro";
import { withBase } from "../../../utils/url";

export async function getStaticPaths() {
  const entries = await getCollection("examples");

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const source = transformUrls(entry.data.source)

function transformUrls(source: string) {
  return source.replace(
    /(["'`])(\/(?!\/)[^"'`]*)\1/g,
    (_: string, quote: string, path: string) => {
      return `${quote}${withBase(path)}${quote}`
    }
  )
}

---

<Example title={entry.data.title} source={source} />
